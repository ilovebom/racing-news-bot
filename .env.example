# 环境变量配置模板
# 复制此文件为 .env 并填写真实值

# ============================================================
# AI API 配置（用于翻译、摘要、排版）
# ============================================================

# DeepSeek API（推荐，便宜好用）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 或者使用通义千问 API
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# AI 模型选择：deepseek-chat 或 qwen-turbo
AI_MODEL=deepseek-chat

# ============================================================
# 新闻源配置
# ============================================================

# 启用哪些新闻类别（逗号分隔）
# 可选值：F1,NASCAR,MotoGP,WRC,国内赛车,中国GT,澳门格兰披治
# 留空则启用所有类别
ENABLED_CATEGORIES=F1,NASCAR,中国GT,国内赛车

# 新闻时间范围（天数）
# 最近 N 天内的新闻才会被抓取
NEWS_MAX_AGE_DAYS=7

# 每个类别最多抓取新闻条数
MAX_NEWS_PER_CATEGORY=10

# ============================================================
# 微信公众号发布配置
# ============================================================

# 方案 A：使用 Playwright 浏览器自动化（需要微信扫码登录）
# 设置为 true 则启用自动发布，false 则只生成草稿
AUTO_PUBLISH=false

# 公众号登录 Cookie（首次运行后自动保存，过期需重新扫码）
WECHAT_COOKIE_PATH=data/wechat_cookies.json

# 发布时间（每天定时发布）
PUBLISH_HOUR=10
PUBLISH_MINUTE=0

# ============================================================
# 内容处理配置
# ============================================================

# 每天最多发布新闻条数（最终文章中的新闻条数）
MAX_NEWS_PER_DAY=8

# 是否翻译英文新闻标题
TRANSLATE_TITLES=true

# 是否生成英文标题对照
SHOW_ENGLISH_TITLE=true

# 文章语言：zh（中文）或 en（英文）
ARTICLE_LANG=zh

# ============================================================
# 其他配置
# ============================================================

# 是否发送邮件通知（可选）
ENABLE_EMAIL_NOTIFY=false
EMAIL_TO=

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
